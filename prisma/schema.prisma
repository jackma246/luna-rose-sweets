generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  confirmed
  deposit_received
  prepping
  cake_prepped
  ready
  delivered
  completed
  cancelled
}

enum ExpenseCategory {
  ingredient
  supply
  packaging
  other
}

enum OrderSource {
  fb_marketplace
  tiktok
  instagram
  website
}

enum InventoryCategory {
  ingredient
  supply
  packaging
  equipment
  other
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    Int         @unique @default(autoincrement())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customerName   String
  customerEmail  String
  customerPhone  String?

  items          Json        // CartItem[]
  adjustments    Json        @default("[]") // [{label,amount}] — tips, discounts, custom lines
  totalPrice     Decimal     @db.Decimal(10, 2)

  neededDate     DateTime?   @db.Date
  customerNotes  String?     // what the customer typed in the form
  internalNotes  String?     // owner's working notes

  status         OrderStatus @default(pending)
  source         OrderSource @default(website)
  remindersSent  String[]    @default([]) // e.g. ["d3","d2","d0"]

  images         OrderImage[]

  @@index([neededDate])
  @@index([status])
  @@index([createdAt])
  @@index([source])
}

model OrderImage {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filename     String   // uuid-based name on disk
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  @@index([orderId])
}

model InventoryItem {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  name               String
  quantity           Decimal           @db.Decimal(10, 2)
  unit               String?           // e.g. "lbs", "cups", "ea", "rolls"
  category           InventoryCategory @default(ingredient)
  lowStockThreshold  Decimal?          @db.Decimal(10, 2)
  notes              String?

  @@index([category])
  @@index([name])
}

model Expense {
  id         String          @id @default(cuid())
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  date       DateTime        @db.Date
  amount     Decimal         @db.Decimal(10, 2)
  vendor     String          // where bought (Costco, Amazon, etc.)
  category   ExpenseCategory
  notes      String?
  receiptUrl String?

  @@index([date])
  @@index([category])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  actorType    String
  actorId      String
  method       String
  path         String
  action       String?
  targetType   String?
  targetId     String?
  requestJson  Json?
  responseJson Json?
  ok           Boolean

  @@index([createdAt])
  @@index([actorType])
  @@index([targetType, targetId])
}
